{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hr-erp.local/schemas/orchestrator-human-issue-handoff.schema.json",
  "title": "OrchestratorHumanIssueHandoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ticketId",
    "summary",
    "humanReadableOriginal",
    "requiresPoCheckpoint",
    "riskTier"
  ],
  "definitions": {
    "riskTier": {
      "type": "string",
      "enum": ["T0", "T1", "T2", "T3", "T4"],
      "description": "Agent governance risk tier per governance-manifest.yaml v2"
    },
    "agentFunction": {
      "type": "string",
      "enum": [
        "scout",
        "architect",
        "builder",
        "custodian",
        "packaging",
        "release_ops",
        "integrator",
        "counsel",
        "ai_governance_reviewer",
        "mlops_reviewer",
        "sentinel",
        "verifier",
        "finops_coordinator",
        "advocate"
      ]
    },
    "skillId": {
      "type": "string",
      "enum": [
        "skill-router",
        "governance-tier-gate",
        "concise-planning",
        "repo-architect",
        "cc-skill-security-review",
        "lint-and-validate",
        "testing-patterns",
        "hr-product-gate",
        "hr-domain-boundaries",
        "hr-data-custody",
        "hr-regulated-domain",
        "hr-quality-lab",
        "hr-swarm-governance",
        "hr-contributor-handoff",
        "cursor-harness-scope",
        "hr-orchestration-lanes",
        "hr-human-collaboration",
        "hr-foundation-governance",
        "hr-governance-learning",
        "hr-product-mcp-governance",
        "protect-mcp-governance",
        "devops-product-lifecycle",
        "hr-devops-lifecycle"
      ]
    },
    "cursorModelTier": {
      "type": "string",
      "enum": ["fast", "medium", "largest"]
    },
    "delegatedTaskPlanItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent", "riskTier"],
      "properties": {
        "intent": {
          "type": "string",
          "description": "Human-readable task purpose"
        },
        "function": { "$ref": "#/definitions/agentFunction" },
        "riskTier": { "$ref": "#/definitions/riskTier" },
        "modelTier": { "$ref": "#/definitions/cursorModelTier" },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string" },
          "description": "function ids or intent keys that must complete first"
        },
        "parallelGroup": {
          "type": "string",
          "description": "Tasks with same group may run concurrently"
        },
        "readonly": {
          "type": "boolean",
          "description": "Lane must not write app code"
        },
        "writePaths": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob allowlist when lane may write"
        },
        "skills": {
          "type": "array",
          "items": { "$ref": "#/definitions/skillId" }
        },
        "agentRules": {
          "type": "array",
          "items": { "type": "string" },
          "description": "agent-*.mdc rule ids"
        }
      }
    }
  },
  "properties": {
    "ticketId": { "type": "string" },
    "source": { "type": "string" },
    "summary": { "type": "string" },
    "riskTier": { "$ref": "#/definitions/riskTier" },
    "poCheckpoint": { "type": "string" },
    "impact": { "type": "string" },
    "reproduction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "steps": { "type": "array", "items": { "type": "string" } }
      }
    },
    "expectedVsActual": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expected": { "type": "string" },
        "actual": { "type": "string" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "os": { "type": "string" },
        "nodeVersion": { "type": "string" },
        "branch": { "type": "string" },
        "commitSha": { "type": "string" }
      }
    },
    "suspectedPaths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "orchestratorHints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "conditionalSkills": {
      "type": "array",
      "items": { "$ref": "#/definitions/skillId" }
    },
    "delegatedTaskPlan": {
      "type": "array",
      "items": { "$ref": "#/definitions/delegatedTaskPlanItem" }
    },
    "failureArtifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "logsExcerpt": { "type": "string" },
        "failureSummaryBlock": { "type": "string" }
      }
    },
    "humanReadableOriginal": { "type": "string" },
    "requiresPoCheckpoint": { "type": "boolean" },
    "sopCycleId": {
      "type": "string",
      "description": "S&OP cycle identifier (e.g. 2026-W22)"
    },
    "valueDeliveryRecordPath": {
      "type": "string",
      "description": "Path to value-delivery-record.md for this ship"
    },
    "evidenceBundlePath": {
      "type": "string",
      "description": "Path to governance evidence bundle JSON (required T3+ strict)"
    },
    "laneSignoffPath": {
      "type": "string",
      "description": "Path to lane sign-off attestation JSON"
    },
    "advocateNotes": { "type": "string" },
    "reproStatus": {
      "type": "string",
      "enum": ["reproduced", "could_not_reproduce", "not_attempted"]
    },
    "compliancePosture": {
      "type": "string",
      "enum": ["NIST AI RMF", "EU AI Act employment-AI", "ISO 42001-ready"]
    },
    "delegationDepth": { "type": "integer", "minimum": 0 },
    "toolClasses": {
      "type": "array",
      "items": { "type": "string" }
    },
    "principal": { "type": "string" },
    "learningSignals": {
      "type": "array",
      "description": "Optional Adaptation plane signal_ids referenced in this handoff",
      "items": { "type": "string", "format": "uuid" }
    },
    "planModeArtifact": {
      "type": "string",
      "description": "Path to .cursor/plans/*.md collaboration artifact"
    },
    "collaborationPlan": {
      "type": "object",
      "description": "Collaboration plane (Harness HITL) structured plan",
      "properties": {
        "phase": { "type": "string" },
        "oversightMode": { "type": "string", "enum": ["HITL", "HOTL"] },
        "decisionOverview": { "type": "string" },
        "recommendedStrategyId": { "type": "string" },
        "revalidationRequired": { "type": "boolean" },
        "revalidationConfirmed": { "type": "boolean" },
        "outputReviewRequired": { "type": "boolean" },
        "outputReviewPassed": { "type": "boolean" }
      }
    },
    "humanDecisionRecord": {
      "type": "object",
      "properties": {
        "chosenStrategy": { "type": "string" },
        "principal": { "type": "string" },
        "recordedAt": { "type": "string", "format": "date-time" },
        "rejectionHistory": { "type": "array", "items": { "type": "object" } }
      }
    },
    "revalidationConfirmed": {
      "type": "boolean",
      "description": "Collaboration phase 5 complete; required T3+ strict merge"
    },
    "outputReviewPassed": {
      "type": "boolean",
      "description": "Collaboration phase 7 complete"
    }
  }
}
