{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hr-erp.local/schemas/governance-lane-signoff.schema.json",
  "title": "GovernanceLaneSignoff",
  "type": "object",
  "additionalProperties": false,
  "required": ["handoffId", "ticketId", "principal", "generatedAt", "lanes"],
  "properties": {
    "handoffId": { "type": "string", "minLength": 1 },
    "ticketId": { "type": "string", "minLength": 1 },
    "principal": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["function", "verifier", "signedAt"],
        "properties": {
          "function": { "type": "string", "minLength": 1 },
          "verifier": { "type": "string", "minLength": 1 },
          "artifactPath": { "type": ["string", "null"] },
          "signedAt": { "type": "string", "format": "date-time" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
