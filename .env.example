# Copy to `.env` for local development. Values match `docker-compose.yml` (dev-only).
DATABASE_URL="postgresql://hr_erp:hr_erp_dev_password@localhost:5432/hr_erp?schema=public"

# HS256 secret for `Authorization: Bearer` JWTs / middleware + `/api/v1/*` (dev-only; min 32 chars in production).
JWT_SECRET="replace-with-long-random-secret-min-32-chars"

# Optional pg pool cap per Node process (default 20).
# PG_POOL_MAX=20

# Optional: issue dev tokens — `node scripts/issue-dev-jwt.mjs`
# DEV_TENANT_ID=
# DEV_SUBJECT_ID=

# Optional AES field encryption dev keys — see lib/security/field-crypto.ts
# FIELD_ENCRYPTION_KEY_v1=<64 hex chars>

# Redis for BullMQ integration workers (matches docker-compose `redis` service).
REDIS_URL="redis://127.0.0.1:6379"

# Kafka + dedicated Postgres (bounded contexts): docker compose --profile architecture up -d
KAFKA_BROKERS="localhost:9092"
CORE_HR_DATABASE_URL="postgresql://core_hr:core_hr_dev_password@localhost:5433/core_hr"
PAYROLL_DATABASE_URL="postgresql://payroll:payroll_dev_password@localhost:5434/payroll"
# Outbox relay (`npm run outbox:kafka`): ONE database URL per process.
# OUTBOX_DATABASE_URL="$CORE_HR_DATABASE_URL"

# Passphrase / string — derives AES key via SHA-256 (see lib/integrations/crypto/tokens.ts).
INTEGRATION_SECRET_KEY="dev-integration-token-passphrase-change-me"
# Demo vendor webhook HMAC secret (must match sender).
DEMO_WEBHOOK_SECRET="dev-demo-webhook-secret-change-me"

# Global localization lab (`/global-l10n/*`) — Prisma seed uses this org id.
DEMO_TENANT_ID="default-tenant"
# Optional shortcuts for `npm run holiday:sync`
# HOLIDAY_CALENDAR_ID=
# HOLIDAY_SYNC_YEAR=2026

# Predictive HR / analytics (local)
# DEMO_TENANT_ID="a0000001-0001-4000-8000-000000000001"
# ANALYTICS_DEMO_MODE="1"
# ML_SERVING_URL="http://127.0.0.1:8090"
# After seed, set DEMO_TARGET_ROLE_ID to a `job_roles.id` for the skills matcher UI.
# DEMO_TARGET_ROLE_ID=

# Frontend SPA (leave empty when calling same-origin Next routes such as `/api/mock/*`).
# NEXT_PUBLIC_API_BASE_URL=
