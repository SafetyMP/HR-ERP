# Copy to `.env` for local development. Replace placeholders — never commit real secrets.
# Full Phase 1 contract: docs/operations/vercel-managed-phase1-environment.md

# -----------------------------------------------------------------------------
# PostgreSQL (Prisma app DB) — default matches docker-compose publish port **15432**
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://hr_erp:hr_erp_dev_password@localhost:15432/hr_erp?schema=public"
# Host port mapping when 15432 is taken: `HR_ERP_PG_PUBLISH=15433 docker compose up -d`
# HR_ERP_PG_PUBLISH=15432

# Non-pooled URL for `prisma migrate` against Neon/Vercel when the pooler rejects DDL (optional).
# DIRECT_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# -----------------------------------------------------------------------------
# JWT — HS256 for `Authorization: Bearer` on `/api/v1/*` (middleware + lib/security/jwt.ts)
# -----------------------------------------------------------------------------
JWT_SECRET="replace-with-long-random-secret-min-32-chars"

# -----------------------------------------------------------------------------
# Dev JWT helper (`npm run jwt:dev`) — signs locally with JWT_SECRET
# -----------------------------------------------------------------------------
# DEV_TENANT_ID=
# DEV_SUBJECT_ID=
# DEV_SUBJECT_EMPLOYEE_ID=
# DEV_ROLES=employee
# DEV_OMIT_SUBJECT_EMPLOYEE_ID=
# Tenant fallback order for jwt scripts: DEV_TENANT_ID → DEMO_TENANT_ID → NEXT_PUBLIC_DEMO_TENANT_ID

# Optional pg pool cap per Node process (default 20).
# PG_POOL_MAX=20

# Optional AES field encryption dev keys — pattern FIELD_ENCRYPTION_KEY_<version> (64 hex chars); see lib/security/field-crypto.ts
# FIELD_ENCRYPTION_KEY_v1=

# -----------------------------------------------------------------------------
# Redis — BullMQ integration workers (`npm run worker:integrations`)
# -----------------------------------------------------------------------------
REDIS_URL="redis://127.0.0.1:6379"

# -----------------------------------------------------------------------------
# Kafka + dedicated Postgres (bounded contexts) — `docker compose --profile architecture up -d`
# -----------------------------------------------------------------------------
KAFKA_BROKERS="localhost:9092"
CORE_HR_DATABASE_URL="postgresql://core_hr:core_hr_dev_password@localhost:5433/core_hr"
PAYROLL_DATABASE_URL="postgresql://payroll:payroll_dev_password@localhost:5434/payroll"

# Outbox relay (`npm run outbox:kafka`): one database URL per process.
# OUTBOX_DATABASE_URL="$CORE_HR_DATABASE_URL"
# OUTBOX_POLL_MS=1000
# OUTBOX_BATCH_SIZE=50

# -----------------------------------------------------------------------------
# Integrations lab — demo vendor crypto + webhooks (see specs/integrations-demo-runbook.md)
# -----------------------------------------------------------------------------
INTEGRATION_SECRET_KEY="dev-integration-token-passphrase-change-me"
DEMO_WEBHOOK_SECRET="dev-demo-webhook-secret-change-me"

# -----------------------------------------------------------------------------
# Demo tenant & global L10n lab (`/global-l10n/*`; Prisma seeds use this org id)
# -----------------------------------------------------------------------------
DEMO_TENANT_ID="default-tenant"
# Client-visible fallback for tenant resolution / jwt:dev tenant chain (optional).
# NEXT_PUBLIC_DEMO_TENANT_ID=

# Predictive HR seed (`npm run db:seed:predictive` / `demo:bootstrap`) overrides when set after bootstrap:
# DEMO_PAYSTUB_EMPLOYEE_ID=
# DEMO_MANAGER_EMPLOYEE_ID=
# DEMO_ONBOARDING_TEMPLATE_ID=

# `npm run holiday:sync` / `demo:bootstrap` holiday year override:
# HOLIDAY_CALENDAR_ID=
# HOLIDAY_SYNC_YEAR=2026

# Analytics demo gate (non-production only; see lib/analytics/demo-auth.ts):
# ANALYTICS_DEMO_MODE=1
# Churn scoring backend — local uvicorn or injected ML_SERVING_URL on Vercel:
# ML_SERVING_URL="http://127.0.0.1:8090"

# Skills matcher (`/analytics/skills`): seed job_roles.id from predictive demo:
# DEMO_TARGET_ROLE_ID=

# -----------------------------------------------------------------------------
# Frontend — SPA calling a separate API tier only (omit for same-origin `/api/*`).
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_BASE_URL=

# -----------------------------------------------------------------------------
# OpenTelemetry — optional; Node SDK starts when endpoint set or OTEL_ENABLED=true.
# See docs/operations/vercel-managed-phase1-environment.md (set headers/secrets in Vercel only).
# -----------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=
# OTEL_SERVICE_NAME=hr-erp
# OTEL_ENABLED=

# -----------------------------------------------------------------------------
# Governance APIs — dev-only bypass for auth headers (never enable in production).
# -----------------------------------------------------------------------------
# ALLOW_DEV_GOVERNANCE_HEADERS=

# -----------------------------------------------------------------------------
# Playwright e2e (`npm run test:e2e`) — bearer JWTs for authenticated suites (optional).
# -----------------------------------------------------------------------------
# HR_ERP_PAYSTUB_E2E_JWT=
# HR_ERP_TIME_E2E_JWT=
# HR_ERP_BENEFITS_E2E_JWT=
# HR_ERP_PROFILE_E2E_JWT=
# HR_ERP_PTO_E2E_JWT=
# HR_ERP_LEAVE_E2E_JWT=
# HR_ERP_MANAGER_TEAM_E2E_JWT=
# HR_ERP_ONBOARDING_E2E_JWT=
# HR_ERP_HR_CASE_E2E_JWT=
