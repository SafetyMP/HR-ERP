# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
node_modules.bak.*/
.npm-cache-agent/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/tests/generated/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# python (local bytecode — e.g. services/ml-serving)
__pycache__/
*.py[cod]
*$py.class

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# ML artifacts (regenerate via pipelines)
services/ml-serving/artifacts/*.joblib
services/ml-serving/artifacts/*.json
!services/ml-serving/artifacts/.gitkeep

# protect-mcp shadow/receipt artifacts (lib/copilot/governance)
.protect-mcp/
# Cursor hook audit output (shadow mode)
.cursor/hooks-output/
# Local Cursor agent wiring — ship rules/skills/hooks/mcp team allowlist only
.cursor/agents/
.cursor/mcp.local.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
