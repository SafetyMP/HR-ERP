// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Core tenant & people ---

model Organization {
  id                      String          @id
  name                    String
  jurisdictionCountry     String?         @map("jurisdiction_country")
  jurisdictionSubdivision String?         @map("jurisdiction_subdivision")
  reportingCurrency       String?         @map("reporting_currency")
  payoutSplitMode         PayoutSplitMode @default(PERCENT_BASIS_POINTS) @map("payout_split_mode")
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")

  employees                     Employee[]
  holidayCalendars              HolidayCalendar[]
  meetingProposals              MeetingProposal[]
  payrollPeriods                PayrollPeriod[]
  paymentInstructions           PaymentInstruction[]
  benefitEnrollments            BenefitEnrollment[]
  benefitElectionChangeRequests BenefitElectionChangeRequest[]
  taxYearDocuments              TaxYearDocument[]
  onboardingTemplates           OnboardingTemplate[]
  attendanceCorrectionRequests  AttendanceCorrectionRequest[]
  sprints                       Sprint[]

  @@map("organizations")
}

/// Core HR employee — tenant key matches Organization.id
model Employee {
  id                           String  @id @default(uuid())
  tenantId                     String  @map("tenant_id")
  email                        String
  firstName                    String? @map("first_name")
  lastName                     String? @map("last_name")
  /// Display / IT provisioning — distinct from legal given/family names (Feature 004).
  preferredName                String? @map("preferred_name")
  personalEmail                String? @map("personal_email")
  phone                        String? @map("phone")
  mailingAddressLine1          String? @map("mailing_address_line1")
  mailingAddressLine2          String? @map("mailing_address_line2")
  mailingCity                  String? @map("mailing_city")
  mailingRegion                String? @map("mailing_region")
  mailingPostalCode            String? @map("mailing_postal_code")
  mailingCountry               String? @map("mailing_country")
  emergencyContactName         String? @map("emergency_contact_name")
  emergencyContactPhone        String? @map("emergency_contact_phone")
  emergencyContactRelationship String? @map("emergency_contact_relationship")

  managerId    String? @map("manager_id")
  departmentId String? @map("department_id")
  jobRoleId    String? @map("job_role_id")

  status              EmployeeStatus @default(ACTIVE)
  hireDate            DateTime?      @map("hire_date")
  terminationDate     DateTime?      @map("termination_date")
  anonymizedPseudonym String?        @map("anonymized_pseudonym")

  /// Soft-delete + retention mixin (ADR 0004). `deleted_at` excludes rows from
  /// default reads; `retention_expires_at` arms hard purge by the retention job.
  deletedAt          DateTime? @map("deleted_at")
  retentionExpiresAt DateTime? @map("retention_expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  manager       Employee?   @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports Employee[]  @relation("EmployeeManager")
  department    Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobRole       JobRole?    @relation(fields: [jobRoleId], references: [id], onDelete: SetNull)

  onboardingTasks                OnboardingTask[]
  vendorLinks                    EmployeeVendorLink[]
  workContext                    EmployeeWorkContext?
  schedulingPreference           SchedulingPreference?
  holidayRegions                 EmployeeHolidayRegion[]
  meetingProposalsOrg            MeetingProposal[]              @relation("MeetingOrganizer")
  meetingParticipations          MeetingProposalParticipant[]
  paymentInstructions            PaymentInstruction[]
  capacityAdjustments            CapacityAdjustment[]
  sprintCapacityRows             SprintCapacitySummary[]
  attendancePunches              AttendancePunch[]
  ptoRequests                    PtoRequest[]
  compensationRecords            CompensationRecord[]
  ptoBalances                    PtoBalance[]
  performanceReviews             PerformanceReview[]
  employmentEvents               EmploymentEvent[]
  employeeSkills                 EmployeeSkill[]
  userAccounts                   UserAccount[]
  analyticsFeatureSnapshots      AnalyticsFeatureSnapshot[]
  churnScores                    ChurnScore[]
  benefitEnrollments             BenefitEnrollment[]
  benefitElectionChangeRequests  BenefitElectionChangeRequest[]
  taxYearDocuments               TaxYearDocument[]
  timeOffRequests                TimeOffRequest[]
  timeOffDecisions               TimeOffRequest[]               @relation("TimeOffDecidedBy")
  hrCaseRequests                 HrCaseRequest[]
  attendanceCorrectionSubjects   AttendanceCorrectionRequest[]  @relation("AttendanceCorrectionSubject")
  attendanceCorrectionsSubmitted AttendanceCorrectionRequest[]  @relation("AttendanceCorrectionSubmittedBy")
  attendanceCorrectionsDecided   AttendanceCorrectionRequest[]  @relation("AttendanceCorrectionDecidedBy")
  employeeSeparationTasks        EmployeeSeparationTask[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, managerId])
  @@index([tenantId, jobRoleId])
  @@map("employees")
}

/// QA / chaos PTO request row (one per employee calendar day per tenant) — see `add_pto_requests` migration.
model PtoRequest {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  employeeId     String   @map("employee_id")
  requestDate    DateTime @map("request_date") @db.Date
  idempotencyKey String?  @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, requestDate])
  @@index([tenantId, employeeId])
  @@map("pto_requests")
}

/// Employee-submitted multi-day time-off request (Feature 006); manager decision fields (Feature 011).
model TimeOffRequest {
  id                  String               @id @default(uuid())
  tenantId            String               @map("tenant_id")
  employeeId          String               @map("employee_id")
  startDate           DateTime             @map("start_date") @db.Date
  endDate             DateTime             @map("end_date") @db.Date
  status              TimeOffRequestStatus @default(PENDING)
  note                String?
  decidedAt           DateTime?            @map("decided_at")
  decidedByEmployeeId String?              @map("decided_by_employee_id")
  decisionNote        String?              @map("decision_note")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  decidedBy Employee? @relation("TimeOffDecidedBy", fields: [decidedByEmployeeId], references: [id], onDelete: SetNull)

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("time_off_requests")
}

enum TimeOffRequestStatus {
  PENDING
  APPROVED
  DENIED
}

/// Lightweight HR / payroll intake ticket from employee self-service (Feature 010 + 012 lifecycle).
model HrCaseRequest {
  id                  String         @id @default(uuid())
  tenantId            String         @map("tenant_id")
  employeeId          String         @map("employee_id")
  category            HrCaseCategory @map("category")
  body                String
  status              HrCaseStatus   @default(OPEN)
  /// Short HR-facing note surfaced to the employee on status updates (no full case-management parity).
  employeeVisibleNote String?        @map("employee_visible_note")
  /// Soft-delete + retention mixin (ADR 0004).
  deletedAt           DateTime?      @map("deleted_at")
  retentionExpiresAt  DateTime?      @map("retention_expires_at")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId])
  @@map("hr_case_requests")
}

enum HrCaseCategory {
  PAYROLL
  BENEFITS
  HR_OTHER
}

enum HrCaseStatus {
  OPEN
  ACKNOWLEDGED
  NEEDS_INFO
  RESOLVED
}

model Department {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  name     String
  code     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employees Employee[]
  jobRoles  JobRole[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("departments")
}

model JobRole {
  id             String  @id @default(uuid())
  tenantId       String  @map("tenant_id")
  title          String
  level          String?
  departmentId   String? @map("department_id")
  canonicalTitle String? @map("canonical_title")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  department       Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employees        Employee[]
  roleSkillTargets RoleSkillTarget[]
  marketBenchmarks MarketBenchmark[]
  benchmarkAlerts  BenchmarkAlert[]
  jobTitleMaps     JobTitleMap[]

  @@index([tenantId])
  @@index([tenantId, title])
  @@map("job_roles")
}

model CompensationRecord {
  id               String   @id @default(uuid())
  employeeId       String   @map("employee_id")
  baseAmount       Decimal  @map("base_amount") @db.Decimal(14, 2)
  currency         String   @default("USD")
  effectiveFrom    DateTime @map("effective_from")
  bandPosition     Float?   @map("band_position")
  internalBandCode String?  @map("internal_band_code")

  createdAt DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, effectiveFrom])
  @@map("compensation_records")
}

model PtoBalance {
  id           String   @id @default(uuid())
  employeeId   String   @map("employee_id")
  balanceHours Decimal  @map("balance_hours") @db.Decimal(10, 2)
  asOfDate     DateTime @map("as_of_date")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, asOfDate])
  @@map("pto_balances")
}

model PerformanceReview {
  id             String   @id @default(uuid())
  employeeId     String   @map("employee_id")
  periodStart    DateTime @map("period_start")
  periodEnd      DateTime @map("period_end")
  overallRating  Float?   @map("overall_rating")
  sentimentScore Float?   @map("sentiment_score")

  createdAt DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("performance_reviews")
}

model EmploymentEvent {
  id         String              @id @default(uuid())
  employeeId String              @map("employee_id")
  eventType  EmploymentEventType @map("event_type")
  occurredAt DateTime            @map("occurred_at")
  metadata   Json?

  createdAt DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, occurredAt])
  @@index([eventType])
  @@map("employment_events")
}

model Skill {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  name     String
  slug     String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employeeSkills   EmployeeSkill[]
  roleSkillTargets RoleSkillTarget[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("skills")
}

model EmployeeSkill {
  id          String @id @default(uuid())
  employeeId  String @map("employee_id")
  skillId     String @map("skill_id")
  proficiency Int
  embedding   Json?

  updatedAt DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  skill    Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([employeeId, skillId])
  @@index([skillId])
  @@map("employee_skills")
}

model RoleSkillTarget {
  jobRoleId  String @map("job_role_id")
  skillId    String @map("skill_id")
  importance Float  @default(1)

  jobRole JobRole @relation(fields: [jobRoleId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobRoleId, skillId])
  @@map("role_skill_targets")
}

model UserAccount {
  id         String  @id @default(uuid())
  tenantId   String  @map("tenant_id")
  email      String
  employeeId String? @map("employee_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee         Employee?            @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  roles            UserRoleAssignment[]
  auditLogsAsActor AuditLog[]           @relation("AuditActor")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("user_accounts")
}

model UserRoleAssignment {
  userId String  @map("user_id")
  role   AppRole

  user UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@map("user_role_assignments")
}

model AuditLog {
  id           String  @id @default(uuid())
  tenantId     String  @map("tenant_id")
  actorUserId  String? @map("actor_user_id")
  action       String
  resourceType String  @map("resource_type")
  resourceId   String  @map("resource_id")
  details      Json?

  createdAt DateTime @default(now()) @map("created_at")

  actor UserAccount? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

model AnalyticsFeatureSnapshot {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  employeeId        String   @map("employee_id")
  snapshotDate      DateTime @map("snapshot_date")
  features          Json
  churnedWithin180d Boolean? @map("churned_within_180d")
  etlVersion        String?  @map("etl_version")

  createdAt DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, snapshotDate])
  @@index([employeeId])
  @@map("analytics_feature_snapshots")
}

model ChurnScore {
  id           String @id @default(uuid())
  tenantId     String @map("tenant_id")
  employeeId   String @map("employee_id")
  score        Float
  drivers      Json
  modelVersion String @map("model_version")

  scoredAt DateTime @default(now()) @map("scored_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, scoredAt])
  @@index([employeeId])
  @@map("churn_scores")
}

model ModelRegistry {
  id           String  @id @default(uuid())
  modelType    String  @map("model_type")
  version      String
  artifactUri  String  @map("artifact_uri")
  metrics      Json?
  isProduction Boolean @default(false) @map("is_production")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([modelType, version])
  @@index([modelType, isProduction])
  @@map("model_registry")
}

model MarketBenchmark {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  jobRoleId     String?  @map("job_role_id")
  geoCode       String   @map("geo_code")
  currency      String   @default("EUR")
  provider      String   @default("mock_provider")
  p50Annual     Decimal? @map("p50_annual") @db.Decimal(14, 2)
  p75Annual     Decimal? @map("p75_annual") @db.Decimal(14, 2)
  p90Annual     Decimal? @map("p90_annual") @db.Decimal(14, 2)
  sampleSize    Int?     @map("sample_size")
  effectiveDate DateTime @map("effective_date")
  rawPayload    Json?    @map("raw_payload")

  createdAt DateTime @default(now()) @map("created_at")

  jobRole JobRole? @relation(fields: [jobRoleId], references: [id], onDelete: SetNull)

  @@index([tenantId, effectiveDate])
  @@index([jobRoleId])
  @@map("market_benchmarks")
}

model BenchmarkAlert {
  id        String                 @id @default(uuid())
  tenantId  String                 @map("tenant_id")
  jobRoleId String?                @map("job_role_id")
  severity  BenchmarkAlertSeverity @default(WARN)
  message   String

  createdAt DateTime  @default(now()) @map("created_at")
  clearedAt DateTime? @map("cleared_at")

  jobRole JobRole? @relation(fields: [jobRoleId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@map("benchmark_alerts")
}

model JobTitleMap {
  id                     String  @id @default(uuid())
  tenantId               String  @map("tenant_id")
  internalTitleKey       String  @map("internal_title_key")
  geoCode                String  @map("geo_code")
  normalizedTitle        String  @map("normalized_title")
  externalOccupationCode String? @map("external_occupation_code")
  jobRoleId              String? @map("job_role_id")

  createdAt DateTime @default(now()) @map("created_at")

  jobRole JobRole? @relation(fields: [jobRoleId], references: [id], onDelete: SetNull)

  @@unique([tenantId, internalTitleKey, geoCode])
  @@index([tenantId])
  @@map("job_title_maps")
}

model EmployeeWorkContext {
  id                      String              @id @default(uuid())
  employeeId              String              @unique @map("employee_id")
  primaryTimezone         String              @map("primary_timezone")
  locale                  String              @default("en-US")
  preferredFirstDayOfWeek Int?                @map("preferred_first_day_of_week")
  calendarSystem          CalendarSystem      @default(GREGORIAN) @map("calendar_system")
  calendarCustomNote      String?             @map("calendar_custom_note")
  honorific               String?
  givenName               String?             @map("given_name")
  familyName              String?             @map("family_name")
  additionalName          String?             @map("additional_name")
  displayName             String?             @map("display_name")
  nameOrderPreference     NameOrderPreference @default(GIVEN_FAMILY) @map("name_order_preference")
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  employee      Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workIntervals WorkInterval[]

  @@map("employee_work_contexts")
}

model WorkInterval {
  id            String @id @default(uuid())
  workContextId String @map("work_context_id")
  /// 0 = Sunday … 6 = Saturday (locale-neutral; UI can relabel)
  dayOfWeek     Int    @map("day_of_week")
  /// Minutes from local midnight (in employee primary zone)
  startMinute   Int    @map("start_minute")
  endMinute     Int    @map("end_minute")

  workContext EmployeeWorkContext @relation(fields: [workContextId], references: [id], onDelete: Cascade)

  @@index([workContextId])
  @@map("work_intervals")
}

model SchedulingPreference {
  id                    String  @id @default(uuid())
  employeeId            String  @unique @map("employee_id")
  asyncFirstDefault     Boolean @default(true) @map("async_first_default")
  overlapWindowMinutes  Int     @default(30) @map("overlap_window_minutes")
  quietHoursStartMinute Int?    @map("quiet_hours_start_minute")
  quietHoursEndMinute   Int?    @map("quiet_hours_end_minute")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("scheduling_preferences")
}

model MeetingProposal {
  id                  String                @id @default(uuid())
  tenantId            String                @map("tenant_id")
  organizerEmployeeId String                @map("organizer_employee_id")
  title               String
  status              MeetingProposalStatus @default(DRAFT)
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  organization Organization                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organizer    Employee                     @relation("MeetingOrganizer", fields: [organizerEmployeeId], references: [id], onDelete: Cascade)
  slots        MeetingProposalSlot[]
  participants MeetingProposalParticipant[]

  @@index([tenantId])
  @@map("meeting_proposals")
}

model MeetingProposalSlot {
  id         String   @id @default(uuid())
  proposalId String   @map("proposal_id")
  startUtc   DateTime @map("start_utc")
  endUtc     DateTime @map("end_utc")

  proposal MeetingProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@map("meeting_proposal_slots")
}

model MeetingProposalParticipant {
  proposalId String @map("proposal_id")
  employeeId String @map("employee_id")

  proposal MeetingProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  employee Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([proposalId, employeeId])
  @@map("meeting_proposal_participants")
}

// --- Payroll splits ---

model PayrollPeriod {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  label     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization        Organization         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentInstructions PaymentInstruction[]

  @@index([tenantId])
  @@map("payroll_periods")
}

model PaymentInstruction {
  id                    String   @id @default(uuid())
  tenantId              String   @map("tenant_id")
  employeeId            String   @map("employee_id")
  payrollPeriodId       String?  @map("payroll_period_id")
  reportingFxSnapshotId String?  @map("reporting_fx_snapshot_id")
  memo                  String?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  organization        Organization   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee            Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollPeriod       PayrollPeriod? @relation(fields: [payrollPeriodId], references: [id], onDelete: SetNull)
  reportingFxSnapshot FxSnapshot?    @relation(fields: [reportingFxSnapshotId], references: [id], onDelete: SetNull)
  lines               PayoutLine[]

  @@index([tenantId])
  @@index([employeeId])
  @@map("payment_instructions")
}

model PayoutLine {
  id                    String         @id @default(uuid())
  paymentInstructionId  String         @map("payment_instruction_id")
  lineType              PayoutLineType @map("line_type")
  sortOrder             Int            @default(0) @map("sort_order")
  /// Amount in minor units when not using percent split
  amountMinor           Int?           @map("amount_minor")
  /// 0–10000 = 0%–100% when using percent-based split
  allocationBasisPoints Int?           @map("allocation_basis_points")
  currencyCode          String?        @map("currency_code")
  cryptoAssetId         String?        @map("crypto_asset_id")

  paymentInstruction PaymentInstruction @relation(fields: [paymentInstructionId], references: [id], onDelete: Cascade)

  @@index([paymentInstructionId])
  @@map("payout_lines")
}

model FxSnapshot {
  id           String   @id @default(uuid())
  fromCurrency String   @map("from_currency")
  toCurrency   String   @map("to_currency")
  rate         Decimal  @db.Decimal(20, 10)
  quotedAt     DateTime @map("quoted_at")
  source       String

  paymentInstructions PaymentInstruction[]

  @@index([fromCurrency, toCurrency, quotedAt])
  @@map("fx_snapshots")
}

// --- Holidays & capacity ---

model HolidayCalendar {
  id                      String    @id @default(uuid())
  tenantId                String    @map("tenant_id")
  jurisdictionCountry     String    @map("jurisdiction_country")
  jurisdictionSubdivision String?   @map("jurisdiction_subdivision")
  name                    String
  version                 Int       @default(1)
  provider                String? // e.g. nager_at
  lastSyncedAt            DateTime? @map("last_synced_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  organization  Organization            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  observations  HolidayObservation[]
  employeeLinks EmployeeHolidayRegion[]

  @@index([tenantId])
  @@map("holiday_calendars")
}

model HolidayObservation {
  id                String          @id @default(uuid())
  holidayCalendarId String          @map("holiday_calendar_id")
  localNameKey      String          @map("local_name_key")
  ruleType          HolidayRuleType @map("rule_type")
  fixedMonth        Int?            @map("fixed_month")
  fixedDay          Int?            @map("fixed_day")
  easterOffsetDays  Int?            @map("easter_offset_days")
  externalId        String?         @map("external_id")
  effectiveFrom     DateTime?       @map("effective_from") @db.Date
  effectiveTo       DateTime?       @map("effective_to") @db.Date
  source            String?

  calendar            HolidayCalendar          @relation(fields: [holidayCalendarId], references: [id], onDelete: Cascade)
  dates               HolidayObservationDate[]
  capacityAdjustments CapacityAdjustment[]

  @@unique([holidayCalendarId, externalId])
  @@index([holidayCalendarId])
  @@map("holiday_observations")
}

model HolidayObservationDate {
