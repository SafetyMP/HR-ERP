  modelVersion          String?              @map("model_version")
  datasetSnapshotId     String?              @map("dataset_snapshot_id")
  explanationSnapshotId String               @unique @map("explanation_snapshot_id")
  proposedBySubjectId   String               @map("proposed_by_subject_id")
