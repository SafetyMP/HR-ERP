// --- Recruiting / ATS ---

enum JobRequisitionStatus {
  DRAFT
  OPEN
  ON_HOLD
  CLOSED
  FILLED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  TEMP
}

enum CandidateSourceChannel {
  CAREERS_SITE
  EMPLOYEE_REFERRAL
  AGENCY
  LINKEDIN
  JOB_BOARD
  EVENT
  OTHER
}

enum JobApplicationStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum JobOfferStatus {
  DRAFT
  PENDING_HITL_APPROVAL
  EXTENDED
  ACCEPTED
  DECLINED
  RESCINDED
  EXPIRED
}

/// A posted role under a tenant. Hiring manager + department + jurisdiction govern offer authorities.
model JobRequisition {
  id              String               @id @default(uuid())
  tenantId        String               @map("tenant_id")
  title           String
  departmentId    String?              @map("department_id")
  jobRoleId       String?              @map("job_role_id")
  hiringManagerId String?              @map("hiring_manager_id")
  status          JobRequisitionStatus @default(DRAFT)
  openings        Int                  @default(1)
  /// ISO-3166-1 alpha-2 — used to gate jurisdiction-aware AI screening defaults.
  locationCountry String?              @map("location_country")
  employmentType  EmploymentType       @default(FULL_TIME) @map("employment_type")
  /// Free-text job description; AI screening must operate on a redacted copy (see lib/recruiting/redact.ts).
  description     String?
  closedAt        DateTime?            @map("closed_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  applications JobApplication[]

  @@index([tenantId, status])
  @@index([tenantId, hiringManagerId])
  @@map("job_requisitions")
}

/// Candidate identity. PII root for ATS — soft-delete + retention drives GDPR right-to-be-forgotten.
model Candidate {
  id                  String                 @id @default(uuid())
  tenantId            String                 @map("tenant_id")
  fullName            String                 @map("full_name")
  email               String
  phone               String?
  sourceChannel       CandidateSourceChannel @default(CAREERS_SITE) @map("source_channel")
  /// Optional masked alternate identifier used by AI scoring snapshots.
  anonymizedPseudonym String?                @map("anonymized_pseudonym")
  /// Soft-delete + retention mixin (ADR 0004).
  deletedAt           DateTime?              @map("deleted_at")
  retentionExpiresAt  DateTime?              @map("retention_expires_at")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  applications JobApplication[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("candidates")
}

/// One candidate's pursuit of one requisition. Stage transitions are HITL-gated for HIRED.
model JobApplication {
  id                        String              @id @default(uuid())
  tenantId                  String              @map("tenant_id")
  requisitionId             String              @map("requisition_id")
  candidateId               String              @map("candidate_id")
  stage                     JobApplicationStage @default(APPLIED)
  /// Most recent AI screening proposal (lib/governance/proposals) used to advance the stage.
  /// HIRED transitions REQUIRE this to point at an APPROVED HIRE-class proposal.
  latestScreeningProposalId String?             @map("latest_screening_proposal_id")
  /// Free-text recruiter note (no PII like SSN — enforced by application validation).
  note                      String?
  appliedAt                 DateTime            @default(now()) @map("applied_at")
  rejectedAt                DateTime?           @map("rejected_at")
  hiredAt                   DateTime?           @map("hired_at")
  createdAt                 DateTime            @default(now()) @map("created_at")
  updatedAt                 DateTime            @updatedAt @map("updated_at")

  requisition JobRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  candidate   Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  offers      JobOffer[]
  interviews  JobInterview[]

  @@unique([tenantId, requisitionId, candidateId])
  @@index([tenantId, stage])
  @@map("job_applications")
}

enum JobInterviewOutcome {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model JobInterview {
  id            String              @id @default(uuid())
  tenantId      String              @map("tenant_id")
  applicationId String              @map("application_id")
  scheduledAt   DateTime            @map("scheduled_at")
  interviewType String              @map("interview_type")
  outcome       JobInterviewOutcome @default(SCHEDULED)
  scorecardJson Json                @default("{}") @map("scorecard_json")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId, applicationId])
  @@map("job_interviews")
}

// --- Performance management ---

enum PerformanceCycleStatus {
  DRAFT
  OPEN
  CALIBRATION
  CLOSED
}

enum PerformanceGoalStatus {
  DRAFT
  ACTIVE
  AT_RISK
  COMPLETE
  CANCELLED
}

enum PerformanceReviewStatus {
  DRAFT
  EMPLOYEE_SUBMITTED
  MANAGER_SUBMITTED
  CALIBRATED
  RELEASED
}

/// A bounded review window across the tenant (e.g. "FY26 H1 Review"). Goals
/// and reviews live inside one cycle; calibration freezes ratings before
/// release.
model PerformanceCycle {
  id             String                 @id @default(uuid())
  tenantId       String                 @map("tenant_id")
  name           String
  startDate      DateTime               @map("start_date") @db.Date
  endDate        DateTime               @map("end_date") @db.Date
  status         PerformanceCycleStatus @default(DRAFT)
  /// Maximum overall rating value used by manager + calibration grids.
  ratingScaleMax Int                    @default(5) @map("rating_scale_max")
  closedAt       DateTime?              @map("closed_at")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  goals   PerformanceGoal[]
  reviews PerformanceReviewV2[]

  @@index([tenantId, status])
  @@map("performance_cycles")
}

/// Employee-owned goal scoped to a cycle. `weight` is in basis points (0–10000)
/// for deterministic rollups; status drives the dashboard pill.
model PerformanceGoal {
  id                String                @id @default(uuid())
  tenantId          String                @map("tenant_id")
  cycleId           String                @map("cycle_id")
  employeeId        String                @map("employee_id")
  title             String
  description       String?
  weightBp          Int                   @default(0) @map("weight_bp")
  status            PerformanceGoalStatus @default(DRAFT)
  percentCompleteBp Int                   @default(0) @map("percent_complete_bp")
  dueDate           DateTime?             @map("due_date") @db.Date
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  cycle PerformanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId, cycleId])
  @@index([tenantId, status])
  @@map("performance_goals")
}

/// Phase 2 performance review row. Distinct from the legacy `PerformanceReview`
/// (kept for analytics back-compat) so we can evolve workflows without
/// breaking the existing churn analytics fixture.
model PerformanceReviewV2 {
  id                 String                  @id @default(uuid())
  tenantId           String                  @map("tenant_id")
  cycleId            String                  @map("cycle_id")
  employeeId         String                  @map("employee_id")
  managerSubjectId   String?                 @map("manager_subject_id")
  status             PerformanceReviewStatus @default(DRAFT)
  selfRating         Int?                    @map("self_rating")
  managerRating      Int?                    @map("manager_rating")
  /// 9-box bucket id 1..9 (1 = top-left, 9 = bottom-right); set during CALIBRATION.
  calibrationBox     Int?                    @map("calibration_box")
  /// Recursive cycle release timestamp; null until status = RELEASED.
  releasedAt         DateTime?               @map("released_at")
  managerNote        String?                 @map("manager_note")
  selfNote           String?                 @map("self_note")
  /// Soft-delete + retention mixin (ADR 0004) — managers may rescind reviews.
  deletedAt          DateTime?               @map("deleted_at")
  retentionExpiresAt DateTime?               @map("retention_expires_at")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")

  cycle PerformanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, cycleId, employeeId])
  @@index([tenantId, status])
  @@map("performance_reviews_v2")
}

// --- Compensation cycles ---

enum CompensationCycleType {
  MERIT
  BONUS
  EQUITY_GRANT
}

enum CompensationCycleStatus {
  DRAFT
  OPEN
  REVIEW
  APPROVED
  APPLIED
  CLOSED
}

enum CompensationRecommendationStatus {
  DRAFT
  AWAITING_APPROVAL
  APPROVED
  REJECTED
  APPLIED
}

/// A merit / bonus / equity planning round. APPROVED status freezes the grid
/// before APPLIED, which writes downstream payroll instructions.
model CompensationCycle {
  id            String                  @id @default(uuid())
  tenantId      String                  @map("tenant_id")
  name          String
  cycleType     CompensationCycleType   @map("cycle_type")
  effectiveDate DateTime                @map("effective_date") @db.Date
  status        CompensationCycleStatus @default(DRAFT)
  /// ISO 4217 currency the cycle is denominated in (recommendations may convert via FX snapshots).
  currencyCode  String                  @map("currency_code")
  closedAt      DateTime?               @map("closed_at")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")

  recommendations CompensationRecommendation[]

  @@index([tenantId, status])
  @@map("compensation_cycles")
}

/// One row per employee per cycle. Manager-authored, HITL-gated before APPLIED.
/// Amounts persisted in **minor units** to keep parity with payroll-calc.
model CompensationRecommendation {
  id                      String                           @id @default(uuid())
  tenantId                String                           @map("tenant_id")
  cycleId                 String                           @map("cycle_id")
  employeeId              String                           @map("employee_id")
  status                  CompensationRecommendationStatus @default(DRAFT)
  baseIncreaseAmountMinor BigInt?                          @map("base_increase_amount_minor")
  bonusAmountMinor        BigInt?                          @map("bonus_amount_minor")
  equityGrantShares       BigInt?                          @map("equity_grant_shares")
  justification           String?
  /// COMPENSATION_CHANGE-class AiDecisionProposal that authorized APPLIED status.
  authorizingProposalId   String?                          @map("authorizing_proposal_id")
  appliedAt               DateTime?                        @map("applied_at")
  createdAt               DateTime                         @default(now()) @map("created_at")
  updatedAt               DateTime                         @updatedAt @map("updated_at")

  cycle CompensationCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, cycleId, employeeId])
  @@index([tenantId, status])
  @@map("compensation_recommendations")
}

/// Offer letter intent. Compensation is stored in MINOR units to match payroll-calc.
model JobOffer {
  id                    String         @id @default(uuid())
  tenantId              String         @map("tenant_id")
  applicationId         String         @map("application_id")
  /// HIRE-class AiDecisionProposal that authorized this offer; required to leave PENDING_HITL_APPROVAL.
  authorizingProposalId String?        @map("authorizing_proposal_id")
  status                JobOfferStatus @default(DRAFT)
  baseAnnualAmountMinor BigInt         @map("base_annual_amount_minor")
  currencyCode          String         @map("currency_code")
  startDate             DateTime?      @map("start_date") @db.Date
  expiresAt             DateTime?      @map("expires_at")
  acceptedAt            DateTime?      @map("accepted_at")
  declinedAt            DateTime?      @map("declined_at")
  rescindedAt           DateTime?      @map("rescinded_at")
  /// Soft-delete + retention mixin (ADR 0004).
  deletedAt             DateTime?      @map("deleted_at")
  retentionExpiresAt    DateTime?      @map("retention_expires_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, applicationId])
  @@map("job_offers")
}

