{
  "version": 1,
  "description": "HR ERP governance hooks — GOVERNANCE_HOOK_MODE=shadow|enforce; manifest v4 lane state",
  "hooks": {
    "sessionStart": [{ "command": "node .cursor/hooks/session-start.mjs", "timeout": 10 }],
    "beforeShellExecution": [
      { "command": "node .cursor/hooks/before-shell.mjs", "timeout": 10, "failClosed": true }
    ],
    "beforeMCPExecution": [
      { "command": "node .cursor/hooks/before-mcp.mjs", "timeout": 10, "failClosed": true }
    ],
    "preToolUse": [
      {
        "command": "node .cursor/hooks/pre-tool-use.mjs",
        "timeout": 10,
        "matcher": "Task"
      }
    ],
    "subagentStart": [{ "command": "node .cursor/hooks/subagent-start.mjs", "timeout": 30 }],
    "subagentStop": [{ "command": "node .cursor/hooks/subagent-stop.mjs", "timeout": 15 }],
    "afterFileEdit": [{ "command": "node .cursor/hooks/after-file-edit.mjs", "timeout": 5 }],
    "beforeSubmitPrompt": [{ "command": "node .cursor/hooks/before-submit-prompt.mjs", "timeout": 15 }],
    "stop": [{ "command": "node .cursor/hooks/stop.mjs", "timeout": 30 }]
  }
}
